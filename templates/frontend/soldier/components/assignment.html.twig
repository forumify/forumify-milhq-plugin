<div class="flex flex-col gap-4">
    {% if soldier.signature %}
        <img class="card" width="100%" height="auto" src="{{ asset(soldier.signature, 'milhq.asset') }}">
    {% endif %}
    <div class="card">
        <div class="card-title">{{ 'milhq.soldier.awards'|trans }}</div>
        {% set awards = awards|filter(a => a.image is not null) %}
        {% if awards is not empty %}
            <div class="card-body grid-xs-4 grid-sm-6 grid-md-12 gap-1">
                {% for award in awards %}
                    <div style="position: relative;" title="{{ award.name }}">
                        <div class="text-center">
                            <img src="{{ asset(award.image, 'milhq.asset') }}" style="width: 100%; height: 42px; object-fit: contain;">
                        </div>
                        {% if award.count > 1 %}
                            <span style="
                                position: absolute;
                                bottom: 8px;
                                right: 8px;
                                text-shadow: -1px -1px 0 var(--c-elevation-0), 1px -1px 0 var(--c-elevation-0), -1px 1px 0 var(--c-elevation-0), 1px 1px 0 var(--c-elevation-0);"
                            >
                                x{{ award.count }}
                            </span>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-small card-body">{{ 'milhq.soldier.no_awards'|trans }}</p>
        {% endif %}
    </div>
    <div class="card">
        <div class="card-title">{{ 'milhq.soldier.secondary_positions'|trans }}</div>
        <div class="card-body">
            <ul class="text-small flex flex-col gap-2">
                {% for unit in secondaryAssignments %}
                    <li>
                        <p class="text-bold">{{ unit.name }}</p>
                        <ul class="ml-2">
                            {% for record in unit.records %}
                                <li>{{ record }}</li>
                            {% endfor %}
                        </ul>
                    </li>
                {% else %}
                    <li>{{ 'milhq.soldier.no_secondary_positions'|trans }}</li>
                {% endfor %}
            </ul>
        </div>
    </div>
    {% if plugin_version('forumify/forumify-milhq-plugin', 'premium') %}
        {% if equipment.primaryWeapons is not empty or equipment.secondaryWeapons is not empty or equipment.vehicles is not empty %}
            <div class="card">
                <div class="card-title">{{ 'milhq.soldier.equipment'|trans }}</div>
                <div class="card-body">
                    {% if equipment.primaryWeapons is not empty %}
                        <ul class="text-small flex flex-col gap-2">
                            <p class="text-bold">{{ 'milhq.soldier.primary_weapons'|trans }}</p>
                            {% for weapon in equipment.primaryWeapons %}
                                <li id="primary-weapons" class="ml-2">{{ weapon.name }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                    {% if equipment.secondaryWeapons is not empty %}
                        <ul class="text-small flex flex-col gap-2 mt-2">
                            <p class="text-bold">{{ 'milhq.soldier.secondary_weapons'|trans }}</p>
                            {% for weapon in equipment.secondaryWeapons %}
                                <li id="secondary-weapons" class="ml-2">{{ weapon.name }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                    {% if equipment.vehicles is not empty %}
                        <ul class="text-small flex flex-col gap-2 mt-2">
                            <p class="text-bold">{{ 'milhq.soldier.vehicles'|trans }}</p>
                            {% for vehicle in equipment.vehicles %}
                                <li id="vehicles" class="ml-2">{{ vehicle.name }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    {% endif %}
</div>
